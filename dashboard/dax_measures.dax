# ADDCOLUMNS(
#     CALENDAR(DATE(2011,1,1), DATE(2014,12,31)),
#     "Year",        YEAR([Date]),
#     "Month",       MONTH([Date]),
#     "MonthName",   FORMAT([Date], "MMM"),
#     "Quarter",     "Q" & QUARTER([Date]),
#     "YearMonth",   FORMAT([Date], "YYYY-MM"),
#     "YearQuarter", FORMAT([Date], "YYYY") & " Q" & QUARTER([Date])
# )
#
# Relationship: superstore_clean[order_date] →(Many) Date[Date] (One)
# Mark as date table: select Date table → Table tools → Mark as date table → Date
